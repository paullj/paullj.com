---
import { content, http } from "../site.config";
import "@fontsource/jetbrains-mono";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	articleDate?: string;
}

const {
	title,
	description = content.description,
	ogImage,
	articleDate,
} = Astro.props;

const titleSeparator = "—";
const _siteTitle = `${title} ${titleSeparator} ${http.title}`;
const _canonicalURL = new URL(Astro.url.pathname, Astro.site);
const _socialImageURL = new URL(
	ogImage ? ogImage : "/social-card.png",
	Astro.url,
).href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{siteTitle}</title>

{/* Favicons */}
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="canonical" href={canonicalURL} />

{/* Primary Meta */}
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={content.name} />
<meta name="theme-color" content="" />
<meta name="generator" content={Astro.generator} />

{/* Open Graph */}
<meta property="og:type" content={articleDate ? "article" : "website"} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={http.title} />
<meta property="og:locale" content={http.og_locale} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{articleDate && (
  <>
    <meta property="article:author" content={content.name} />
    <meta property="article:published_time" content={articleDate} />
  </>
)}

{/* Twitter */}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

{/* Sitemap & RSS */}
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={http.title} href="/rss.xml" />
